# ─── Required ────────────────────────────────────────────────────────────────

# Govee developer API key
# Get one at: https://developer.govee.com → sign in → Apply for API key
GOVEE_API_KEY=your-api-key-here

# First Govee device
# Device ID format: AB:CD:EF:01:02:03:04:05  (from GET /v1/devices)
# Model format:     H6160  (from GET /v1/devices)
GOVEE_DEVICE1_ID=AA:BB:CC:DD:EE:FF:00:11
GOVEE_DEVICE1_MODEL=H6160
GOVEE_DEVICE1_LABEL=Front Light

# ─── Optional second device ──────────────────────────────────────────────────
# Leave blank to operate with only one light.
GOVEE_DEVICE2_ID=
GOVEE_DEVICE2_MODEL=
GOVEE_DEVICE2_LABEL=Back Light

# ─── Optional LAN control (recommended for fast animations) ──────────────────
# Set the local IP of each device to use the Govee LAN UDP API instead of
# the cloud HTTP API. LAN control has no rate limits, enabling fast strobing.
# Requires "LAN Control" to be enabled in the Govee mobile app.
GOVEE_DEVICE1_IP=
GOVEE_DEVICE2_IP=

# ─── General settings ────────────────────────────────────────────────────────

# Port the service listens on
WEBHOOK_PORT=8585

# Seconds before lights restore to previous state after an alarm
ALARM_TIMEOUT=30

# Seconds a single-device test holds the effect before restoring
# (separate from ALARM_TIMEOUT which applies to real webhook triggers)
TEST_DURATION=5

# Default effect when no ?effect= param is provided
# See the web UI for all available effect keys
DEFAULT_EFFECT=white

# Log verbosity: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Log file path inside the container (mapped to ./logs/ on the host)
LOG_FILE=/app/logs/govee_alarm.log
